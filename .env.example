# MERO GAMALA Plant Store - Environment Variables Example
# Copy this file to .env.local for local development

# App Configuration
VITE_APP_NAME="MERO GAMALA"
VITE_APP_VERSION="1.0.0"

# API Configuration (for future use)
# VITE_API_URL=http://localhost:3001
# VITE_API_KEY=your_api_key_here

# Payment Gateway Configuration (for future use)
# VITE_ESEWA_MERCHANT_ID=your_esewa_merchant_id
# VITE_FONEPAY_MERCHANT_ID=your_fonepay_merchant_id

# WhatsApp Integration (for future use)
# VITE_WHATSAPP_BUSINESS_PHONE=+9779766473272
# VITE_WHATSAPP_API_TOKEN=your_whatsapp_api_token

# Analytics (for future use)
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# VITE_FACEBOOK_PIXEL_ID=123456789

# Admin Configuration
# VITE_ADMIN_EMAIL=admin@merogamala.com

# Development flags
# VITE_DEBUG_MODE=true
# VITE_ENABLE_MOCK_DATA=true
# Environment Variables Template for MERO GAMALA
# Copy this file to .env.local and fill in your actual credentials

# eSewa Payment Gateway Configuration
VITE_ESEWA_MERCHANT_ID=your_esewa_merchant_id
VITE_ESEWA_SUCCESS_URL=https://yourwebsite.com/payment-success
VITE_ESEWA_FAILURE_URL=https://yourwebsite.com/payment-failure

# FonePay Payment Gateway Configuration
VITE_FONEPAY_MERCHANT_CODE=your_fonepay_merchant_code
VITE_FONEPAY_USERNAME=your_fonepay_username
VITE_FONEPAY_PASSWORD=your_fonepay_password
VITE_FONEPAY_SECRET_KEY=your_fonepay_secret_key
VITE_FONEPAY_BASE_URL=https://api.fonepay.com

# Citizen Bank QR Payment Configuration
VITE_CITIZEN_BANK_MERCHANT_ID=your_citizen_bank_merchant_id
VITE_CITIZEN_BANK_SECRET_KEY=your_citizen_bank_secret_key
VITE_CITIZEN_BANK_BASE_URL=https://api.citizenbank.com

# WhatsApp Business API Configuration (Optional)
VITE_WHATSAPP_API_URL=https://your-whatsapp-api-endpoint.com
VITE_WHATSAPP_AUTH_TOKEN=your_whatsapp_auth_token

# Development Notes:
# - In development mode, payment gateways run in demo mode
# - Replace all "your_*" values with actual credentials from your payment providers
# - Keep your .env.local file private and never commit it to version control
# - For production deployment, set these as environment variables in your hosting platform

# Application Configuration
VITE_APP_NAME="MERO GAMALA"
VITE_APP_VERSION="1.3.0"

# Database Configuration (Production)
# Uncomment and configure for production database
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=mero_gamala
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your_password
# DATABASE_SSL=true

# API Configuration
# VITE_API_URL=https://api.yourdomain.com
# VITE_API_TIMEOUT=10000

# External Services
# VITE_GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
# VITE_WHATSAPP_API_URL=https://api.whatsapp.com
# VITE_WHATSAPP_API_TOKEN=your_whatsapp_token

# Payment Gateway Configuration
# VITE_ESEWA_MERCHANT_ID=your_esewa_merchant_id
# VITE_FONEPAY_MERCHANT_ID=your_fonepay_merchant_id
# VITE_BANK_ACCOUNT_NUMBER=your_bank_account

# Development Settings
VITE_DEV_MODE=true
VITE_ENABLE_CONSOLE_LOGS=true